):\n","            x = 0\n","            while True:\n","                try:\n","                    return func(*args, **kwargs)\n","                except Exception as e:\n","                    if x == retries:\n","                        log.error(f\"Final retry failed for {func.__name__}: {e}\")\n","                        raise\n","                    sleep = (backoff_in_seconds * 2 ** x)\n","                    log.warning(f\"Retrying {func.__name__} in {sleep}s due to: {e}\")\n","                    time.sleep(sleep)\n","                    x += 1\n","        return wrapper\n","    return decorator\n","\n","# We would apply @retry_with_backoff() to our expert_analyze_pair function\n","print(\"Retry logic engine initialized.\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Retry logic engine initialized.\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7c97c722","executionInfo":{"status":"ok","timestamp":1776818332145,"user_tz":-60,"elapsed":70,"user":{"displayName":"Syed Mehrab","userId":"10016417158375832621"}},"outputId":"ded409f4-fc7c-4e0a-ef88-fcaca8778b80"},"source":["# Cell to check for system errors or validation failures in the logs\n","!grep \"ERROR\" /content/fx_agent.log || echo \"No errors found in logs.\""],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["grep: /content/fx_agent.log: No such file or directory\n","No errors found in logs.\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"8504d56e","executionInfo":{"status":"ok","timestamp":1776818135972,"user_tz":-60,"elapsed":49584,"user":{"displayName":"Syed Mehrab","userId":"10016417158375832621"}},"outputId":"ca7f0418-68d0-4bf6-c8a5-f5029741aa57"},"source":["from google.colab import userdata\n","import os\n","\n","try:\n","    # Load the key from Colab Secrets\n","    api_key = userdata.get('ANTHROPIC_API_KEY')\n","    os.environ['ANTHR