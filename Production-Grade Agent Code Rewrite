opic) (0.16.0)\n","Downloading anthropic-0.96.0-py3-none-any.whl (635 kB)\n","\u001b[?25l   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m0.0/635.9 kB\u001b[0m \u001b[31m?\u001b[0m eta \u001b[36m-:--:--\u001b[0m\r\u001b[2K   \u001b[91m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[91m╸\u001b[0m\u001b[90m━━━━━\u001b[0m \u001b[32m553.0/635.9 kB\u001b[0m \u001b[31m16.4 MB/s\u001b[0m eta \u001b[36m0:00:01\u001b[0m\r\u001b[2K   \u001b[90m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m \u001b[32m635.9/635.9 kB\u001b[0m \u001b[31m12.4 MB/s\u001b[0m eta \u001b[36m0:00:00\u001b[0m\n","\u001b[?25hInstalling collected packages: anthropic\n","Successfully installed anthropic-0.96.0\n"]}]},{"cell_type":"code","source":["from pydantic import BaseModel, Field\n","from typing import List, Optional\n","from datetime import datetime, timezone\n","\n","class KeyLevels(BaseModel):\n","    resistance: List[str]\n","    support: List[str]\n","\n","class TradeSetup(BaseModel):\n","    direction: str = Field(pattern=\"^(Long|Short|Neutral)$\")\n","    entry: str\n","    stop_loss: str\n","    take_profit_1: str\n","    risk_reward: str\n","    stop_atr_ratio: str\n","\n","class TradeBrief(BaseModel):\n","    pair: str\n","    macro_bias: str\n","    confidence: int = Field(ge=0, le=100)\n","    session_context: str\n","    interest_rate_differential: str\n","    risk_environment: str\n","    key_levels: KeyLevels\n","    trade_setup: TradeSetup\n","    carry_trade_note: str\n","    veterans_warning: str\n","    correlation_warning: Optional[str] = None\n","\n","    # Internal metadata fields\n","    generated_at: str = Field(default_factory=lambda: datetime.now(timezone.utc).isoformat())\n","    status: str = Field(default=\"pending_approval\")"],"metadata":{"id":"KvGs-We-agMP"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# content of prompts.py\n","\n","SYSTEM_PROMPT = \"\"\"\n","You are an expert FX Quantitative Analyst and Risk Manager.\n","Your task is to analyze market context data and generate a high-precision Trade Brief.\n","\n","### OPERATIONAL CONSTRAINTS:\n","1. MACRO BIAS: Analyze interest rate differentials and risk environment (Risk-On/Risk-Off).\n","2. TECHNICALS: Identify clean levels of support and resistance.\n","3. RISK MANAGEMENT: Always include a stop-loss and take-profit. Calculate RR ratio.\n","4. VALIDATION: You must output your analysis using the 'submit_trade_brief' tool.\n","\n","### STYLE GUIDELINES:\n","- Be concise and professional.\n","- Use financial terminology correctly.\n","- Highlight specific risks (e.g., central bank speakers, news events).\n","- If the data is contradictory, stay 'Neutral'.\n","\"\"\"\n","\n","DEFAULT_PAIRS = [\n","    \"EUR/USD\",\n","    \"GBP/USD\",\n","    \"USD/JPY\",\n","    \"AUD/USD\",\n","    \"USD/CAD\",\n","    \"EUR/JPY\"\n","]\n"],"metadata":{"id":"3RXGU0m2aa7g"},"execution_count":null,"outputs":[]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"c967efb0","executionInfo":{"status":"ok","timestamp":1776818059538,"user_tz":-60,"elapsed":47,"user":{"displayName":"Syed Mehrab","userId":"10016417158375832621"}},"outputId":"80e2c52f-937f-4289-cb62-68cf84b3e427"},"source":["with open('agent.py', 'r') as f:\n","    print(f.read())"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["\"\"\"\n","FX Agent — Orchestrator\n","-----------------------\n","Feeds market context into Claude and parses structured trade briefs.\n","\n","Requirements:\n","    pip install anthropic requests pandas pytz\n","    export ANTHROPIC_API_KEY=your_key\n","    export TWELVE_DATA_API_KEY=your_key   # optional, falls back to demo data\n","    export SLACK_WEBHOOK_URL=your_webhook  # optional, for Slack delivery\n","\"\"\"\n","\n","import os\n","import json\n","import time\n","import logging\n","from datetime import datetime, timezone\n","from typing import Optional\n","\n","import anthropic\n","\n","from prompts import SYSTEM_PROMPT, DEFAULT_PAIRS\n","from tools import gather_market_context\n","\n","logging.basicConfig(\n","    level=logging.INFO,\n","    format=\"%(asctime)s [%(levelname)s] %(message)s\",\n","    datefmt=\"%Y-%m-%d %H:%M:%S\",\n",")\n","log = logging.getLogger(\"fx_agent\")\n","\n","\n","# ---------------------------------------------------------------------------\n","# CONFIG\n","# ---------------------------------------------------------------------------\n","\n","ANTHROPIC_API_KEY  = os.getenv(\"ANTHROPIC_API_KEY\", \"\")\n","TWELVE_DATA_KEY    = os.getenv(\"TWELVE_DATA_API_KEY\", \"demo\")\n","SLACK_WEBHOOK_URL  = os.getenv(\"SLACK_WEBHOOK_URL\", \"\")\n","MODEL              = \"claude-sonnet-4-20250514\"\n","MAX_TOKENS         = 1500\n","RATE_LIMIT_SECONDS = 3   # pause between pair analyses\n","\n","\n","# ---------------------------------------------------------------------------\n","# CLAUDE CALL\n","# ---------------------------------------------------------------------------\n","\n","def analyze_pair(pair: str, client: anthropic.Anthropic) -> Optional[dict]:\n","    \"\"\"\n","    Gather market context for `pair`, send to Claude, return parsed JSON brief.\n","    Returns None on failure.\n","    \"\"\"\n","    log.info(f\"Analyzing {pair}...\")\n","\n","    # Step 1: gather deterministic context from tools\n","    ctx = gather_market_context(pair, api_key=TWELVE_DATA_KEY)\n","\n","    # Step 2: build the user message\n","    user_message = f\"\"\"Analyze the following pair and produce a trade brief.\n","\n","PAIR: {pair}\n","\n","--- SESSION CONTEXT ---\n","{json.dumps(ctx['session'], indent=2)}\n","\n","--- ATR (VOLATILITY) ---\n","{json.dumps(ctx['atr'], indent=2)}\n","\n","--- PIVOT LEVELS ---\n","{json.dumps(ctx['pivots'], indent=2)}\n","\n","--- CENTRAL BANK BIAS ---\n","{json.dumps(ctx['cb_bias'], indent=2)}\n","\n","Produce your analysis as a single valid JSON object matching the schema in your instructions.\n","Do not include any text outside the JSON object.\"\"\"\n","\n","    # Step 3: call Claude\n","    try:\n","        response = client.messages.create(\n","            model=MODEL,\n","            max_tokens=MAX_TOKENS,\n","            system=SYSTEM_PROMPT,\n","            messages=[{\"role\": \"user\", \"content\": user_message}],\n","        )\n","        raw = response.content[0].text.strip()\n","\n","        # Strip accidental markdown fences\n","        if raw.startswith(\"```\"):\n","            raw = raw.split(\"```\")[1]\n","            if raw.startswith(\"json\"):\n","                raw = raw[4:]\n","        raw = raw.strip()\n","\n","        brief = json.loads(raw)\n","        brief[\"_generated_at\"] = datetime.now(timezone.utc).isoformat()\n","        brief[\"_status\"] = \"pending_approval\"\n","        log.info(f\"  ✓ {pair} — {brief.get('macro_bias','?')} | Confidence {brief.get('confidence','?')}%\")\n","        return brief\n","\n","    except json.JSONDecodeError as e:\n","        log.error(f\"  ✗ {pair} — JSON parse error: {e}\\nRaw output:\\n{raw[:500]}\")\n","        return None\n","    except Exception as e:\n","        log.error(f\"  ✗ {pair} — API error: {e}\")\n","        return None\n","\n","\n","# ---------------------------------------------------------------------------\n","# DELIVERY\n","# ---------------------------------------------------------------------------\n","\n","def format_slack_block(brief: dict) -> dict:\n","    \"\"\"Convert a trade brief into a Slack Block Kit message.\"\"\"\n","    setup = brief.get(\"trade_setup\", {})\n","    direction_emoji = \"📈\" if setup.get(\"direction\") == \"Long\" else \"📉\"\n","    bias_color = \"#2eb886\" if \"Bullish\" in brief.get(\"macro_bias\", \"\") else \"#e01e5a\"\n","\n","    text = (\n","        f\"*{brief['pair']}* — {brief['macro_bias']} | \"\n","        f\"Confidence: {brief.get('confidence', '?')}%\\n\"\n","        f\"{direction_emoji} *{setup.get('direction','?')}* | \"\n","        f\"Entry: `{setup.get('entry','?')}` | \"\n","        f\"SL: `{setup.get('stop_loss','?')}` ({setup.get('stop_loss_pips','?')} pips) | \"\n","        f\"TP1: `{setup.get('take_profit_1','?')}` | \"\n","        f\"R/R: {setup.get('risk_reward','?')}\\n\"\n","        f\"⚠️ *Veteran's Warning:* {brief.get('veterans_warning','')}\\n\"\n","        f\"🏦 *Session:* {brief.get('session_context','')}\\n\"\n","        f\"💱 *Carry:* {brief.get('carry_trade_note','')}\"\n","    )\n","    if brief.get(\"correlation_warning\"):\n","        text += f\"\\n🔗 *Correlation:* {brief['correlation_warning']}\"\n","\n","    return {\n","        \"attachments\": [{\n","            \"color\": bias_color,\n","            \"blocks\": [\n","                {\"type\": \"section\", \"text\": {\"type\": \"mrkdwn\", \"text\": text}},\n","                {\n","                    \"type\": \"actions\",\n","                    \"elements\": [\n","                        {\n","                            \"type\": \"button\",\n","                            \"text\": {\"type\": \"plain_text\", \"text\": \"✅ Approve\"},\n","                            \"style\": \"primary\",\n","                            \"value\": json.dumps({\"action\": \"approve\", \"pair\": brief[\"pair\"], \"ts\": brief[\"_generated_at\"]}),\n","                        },\n","                        {\n","                            \"type\": \"button\",\n","                            \"text\": {\"type\": \"plain_text\", \"text\": \"❌ Reject\"},\n","                            \"style\": \"danger\",\n","                            \"value\": json.dumps({\"action\": \"reject\", \"pair\": brief[\"pair\"], \"ts\": brief[\"_generated_at\"]}),\n","                        },\n","                    ],\n","                },\n","            ],\n","        }]\n","    }\n","\n","\n","def deliver_to_slack(brief: dict) -> bool:\n","    \"\"\"Post a brief to Slack. Returns True on success.\"\"\"\n","    if not SLACK_WEBHOOK_URL:\n","        return False\n","    try:\n","        import requests as req\n","        payload = format_slack_block(brief)\n","        r = req.post(SLACK_WEBHOOK_URL, json=payload, timeout=10)\n","        return r.status_code == 200\n","    except Exception as e:\n","        log.error(f\"Slack delivery failed: {e}\")\n","        return False\n","\n","\n","def print_brief(brief: dict) -> None:\n","    \"\"\"Pretty-print a brief to stdout (fallback when no Slack).\"\"\"\n","    setup = brief.get(\"trade_setup\", {})\n","    direction = setup.get(\"direction\", \"?\")\n","    arrow = \"▲\" if direction == \"Long\" else \"▼\"\n","\n","    print(\"\\n\" + \"═\" * 64)\n","    print(f\"  {brief['pair']}  {arrow} {direction}  |  {brief.get('macro_bias','?')}\")\n","    print(f\"  Confidence: {brief.get('confidence','?')}%  |  Bias Strength: {brief.get('bias_strength','?')}\")\n","    print(\"═\" * 64)\n","    print(f\"  Session   : {brief.get('session_context','')}\")\n","    print(f\"  Entry     : {setup.get('entry','?')}\")\n","    print(f\"  Stop Loss : {setup.get('stop_loss','?')}  ({setup.get('stop_loss_pips','?')} pips)\")\n","    print(f\"  TP1 / TP2 : {setup.get('take_profit_1','?')} / {setup.get('take_profit_2','?')}\")\n","    print(f\"  R/R       : {setup.get('risk_reward','?')}\")\n","    print(f\"  ATR (14d) : {setup.get('atr_daily_pips','?')} pips  |  Stop ratio: {setup.get('stop_atr_ratio','?')}\")\n","    print(f\"  Carry     : {brief.get('carry_trade_note','')}\")\n","    if brief.get(\"correlation_warning\"):\n","        print(f\"  ⚠ Correl  : {brief['correlation_warning']}\")\n","    print(f\"\\n  ★ VETERAN'S WARNING:\\n  {brief.get('veterans_warning','')}\")\n","    print(\"─\" * 64)\n","\n","\n","# ---------------------------------------------------------------------------\n","# SAVE / LOAD\n","# ---------------------------------------------------------------------------\n","\n","BRIEFS_FILE = \"briefs.jsonl\"\n","\n","def save_brief(brief: dict) -> None:\n","    \"\"\"Append a brief to the JSONL audit log.\"\"\"\n","    with open(BRIEFS_FILE, \"a\") as f:\n","        f.write(json.dumps(brief) + \"\\n\")\n","\n","\n","def load_pending_briefs() -> list[dict]:\n","    \"\"\"Return all briefs with status == pending_approval.\"\"\"\n","    briefs = []\n","    try:\n","        with open(BRIEFS_FILE) as f:\n","            for line in f:\n","                b = json.loads(line.strip())\n","                if b.get(\"_status\") == \"pending_approval\":\n","                    briefs.append(b)\n","    except FileNotFoundError:\n","        pass\n","    return briefs\n","\n","\n","# ---------------------------------------------------------------------------\n","# MAIN ORCHESTRATOR\n","# ---------------------------------------------------------------------------\n","\n","def run_analysis(pairs: list[str] = None) -> list[dict]:\n","    \"\"\"\n","    Analyze all pairs, print/deliver briefs, save to audit log.\n","    Returns list of generated briefs.\n","    \"\"\"\n","    if not ANTHROPIC_API_KEY:\n","        raise EnvironmentError(\"Set ANTHROPIC_API_KEY environment variable.\")\n","\n","    pairs = pairs or DEFAULT_PAIRS\n","    client = anthropic.Anthropic(api_key=ANTHROPIC_API_KEY)\n","    briefs = []\n","\n","    log.info(f\"Starting FX analysis run — {len(pairs)} pairs\")\n","    log.info(f\"Model: {MODEL}\")\n","\n","    for i, pair in enumerate(pairs):\n","        brief = analyze_pair(pair, client)\n","        if brief:\n","            briefs.append(brief)\n","            save_brief(brief)\n","            if SLACK_WEBHOOK_URL:\n","                ok = deliver_to_slack(brief)\n","                log.info(f\"  Slack delivery: {'✓' if ok else '✗'}\")\n","            else:\n","                print_brief(brief)\n","        if i < len(pairs) - 1:\n","            time.sleep(RATE_LIMIT_SECONDS)\n","\n","    log.info(f\"Run complete. {len(briefs)}/{len(pairs)} briefs generated.\")\n","    return briefs\n","\n","\n","if __name__ == \"__main__\":\n","    run_analysis()\n","\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"0b4b0f18","executionInfo":{"status":"ok","timestamp":1776817895738,"user_tz":-60,"elapsed":525,"user":{"displayName":"Syed Mehrab","userId":"10016417158375832621"}},"outputId":"dd340942-7eaf-4114-e183-f92e4ffa3fcb"},"source":["import anthropic\n","from google.colab import userdata\n","\n","try:\n","    api_key = userdata.get('ANTHROPIC_API_KEY')\n","    client = anthropic.Anthropic(api_key=api_key)\n","\n","    print(\"Fetching available models for your API key...\\n\")\n","    models = client.models.list()\n","\n","    print(f\"{'Model ID':<30} {'Created At'}\")\n","    print(\"-\" * 50)\n","    for model in models.data:\n","        print(f\"{model.id:<30} {model.created_at}\")\n","\n","except Exception as e:\n","    print(f\"Could not retrieve models: {e}\")\n","    print(\"\\nTip: If you see a 401/403 error, ensure your API key is correct and you have added at least $5 in credits at https://console.anthropic.com/settings/plans\")"],"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Fetching available models for your API key...\n","\n","Model ID                       Created At\n","--------------------------------------------------\n","claude-opus-4-7                2026-04-14 00:00:00+00:00\n","claude-sonnet-4-6              2026-02-17 00:00:00+00:00\n","claude-opus-4-6                2026-02-04 00:00:00+00:00\n","claude-opus-4-5-20251101       2025-11-24 00:00:00+00:00\n","claude-haiku-4-5-20251001      2025-10-15 00:00:00+00:00\n","claude-sonnet-4-5-20250929     2025-09-29 00:00:00+00:00\n","claude-opus-4-1-20250805       2025-08-05 00:00:00+00:00\n"]}]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"21d38725","executionInfo":{"status":"ok","timestamp":1776817956974,"user_tz":-60,"elapsed":1657,"user":{"displayName":"Syed Mehrab","userId":"10016417158375832621"}},"output